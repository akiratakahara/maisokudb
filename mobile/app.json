{
  "expo": {
    "name": "MaisokuDB",
    "slug": "maisoku-db",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maisokudb",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A09"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maisokudb.app",
      "buildNumber": "18",
      "infoPlist": {
        "NSCameraUsageDescription": "物件写真を撮影するためにカメラを使用します",
        "NSPhotoLibraryUsageDescription": "物件画像をアップロードするために写真ライブラリを使用します",
        "CFBundleLocalizations": [
          "ja",
          "ja"
        ],
        "CFBundleDevelopmentRegion": "ja",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.maisokudb.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "983ff559-b35c-45c5-890d-dfdb817c36bd"
      }
    },
    "owner": "akiratakahara"
  }
}
